{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dfc/schemas/system/admirals_data.json",
    "title": "DFC Admirals Data",
    "description": "Generic Admirals and Admiral abilities for any fleet.",
    "type": "object",
    "required": ["admirals", "abilities"],
    "additionalProperties": false,
    "properties": {
        "admirals": {
            "description": "General Admirals available in any fleet.",
            "type": "array",
            "items": {
                "type": "object",
                "required": ["Level", "Cost", "UnavailableIn"],
                "additionalProperties": false,
                "properties": {
                    "Level":         { "type": "integer" },
                    "Cost":          { "type": "integer" },
                    "UnavailableIn": { "type": "array", "items": { "type": "string" } }
                }
            }
        },
        "abilities": {
            "description": "Generic Admiral abilities available to any fleet.",
            "type": "array",
            "items": { "$ref": "https://dfc/schemas/defs.json#/$defs/Ability" }
        }
    }
}
