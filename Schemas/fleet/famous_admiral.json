{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dfc/schemas/fleet/famous_admiral.json",
    "title": "DFC Famous Admiral Data",
    "description": "Data file for a Famous Admiral.",
    "type": "object",
    "required": [
        "admiral",
        "admiral_level",
        "class",
        "type",
        "admiral_points",
        "ship_points",
        "points",
        "tonnage",
        "base_size",
        "profile",
        "weapons",
        "load",
        "upgrades",
        "rules",
        "fleet_admiral_abilities",
        "admiral_abilities",
        "flavour"
    ],
    "additionalProperties": false,
    "properties": {
        "admiral":                 { "type": "string" },
        "admiral_level":           { "type": "integer" },
        "class":                   { "type": "string" },
        "type":                    { "type": "string" },
        "admiral_points":          { "type": "integer" },
        "ship_points":             { "type": "integer" },
        "points":                  { "type": "integer" },
        "tonnage":                 { "$ref": "https://dfc/schemas/fleet/defs.json#/$defs/Tonnage" },
        "base_size":               { "type": "integer" },
        "profile":                 { "$ref": "https://dfc/schemas/fleet/defs.json#/$defs/ShipProfile" },
        "weapons":                 { "type": "array", "items": { "$ref": "https://dfc/schemas/fleet/defs.json#/$defs/Weapon" } },
        "load":                    { "type": "array", "items": { "$ref": "https://dfc/schemas/fleet/defs.json#/$defs/LoadEntry" } },
        "upgrades":                { "type": "array", "items": { "$ref": "https://dfc/schemas/fleet/defs.json#/$defs/UpgradeEntry" } },
        "rules":                   { "type": "array", "items": { "$ref": "https://dfc/schemas/fleet/defs.json#/$defs/Rule" } },
        "fleet_admiral_abilities": { "description": "Number of fleet abilities this admiral may take.", "type": "integer" },
        "admiral_abilities":       { "type": "array", "items": { "$ref": "https://dfc/schemas/fleet/defs.json#/$defs/Ability" } },
        "flavour":                 { "type": "string" }
    }
}
