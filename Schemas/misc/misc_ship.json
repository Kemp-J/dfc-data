{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dfc/schemas/misc/misc_ship.json",
    "title": "DFC Misc Ship Data",
    "description": "Data file for a ship in the Misc PDF. Structurally identical to the civilian ship format; allows points to be null for scenario-only ships.",
    "type": "object",
    "required": [
        "class",
        "type",
        "points",
        "tonnage",
        "base_size",
        "profile",
        "weapons",
        "load",
        "known_ships",
        "flavour"
    ],
    "additionalProperties": false,
    "properties": {
        "class":             { "type": "string" },
        "type":              { "type": "string" },
        "points":            { "type": ["integer", "null"] },
        "tonnage":           { "$ref": "https://dfc/schemas/fleet/defs.json#/$defs/Tonnage" },
        "base_size":         { "type": "integer" },
        "profile":           { "$ref": "https://dfc/schemas/fleet/defs.json#/$defs/ShipProfile" },
        "weapons":           { "type": "array", "items": { "$ref": "https://dfc/schemas/fleet/defs.json#/$defs/Weapon" } },
        "load":              { "type": "array", "items": { "$ref": "https://dfc/schemas/fleet/defs.json#/$defs/LoadEntry" } },
        "upgrades":          { "type": "array", "items": { "$ref": "https://dfc/schemas/fleet/defs.json#/$defs/UpgradeEntry" } },
        "rules":             { "type": "array", "items": { "$ref": "https://dfc/schemas/fleet/defs.json#/$defs/Rule" } },
        "admiral_abilities": { "type": "array", "items": { "$ref": "https://dfc/schemas/fleet/defs.json#/$defs/Ability" } },
        "usable_in":         { "type": "array", "items": { "$ref": "https://dfc/schemas/fleet/defs.json#/$defs/UsableInEntry" } },
        "known_ships":       { "type": "array", "items": { "type": "string" } },
        "flavour":           { "type": "string" }
    }
}
